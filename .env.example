DB_URL=jdbc:postgresql://localhost:5432/smartgym_db
DB_USERNAME=postgres
DB_PASSWORD=root
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

SERVER_PORT=8080

SHOW_SQL=false
FORMAT_SQL=false

HEALTH_SHOW_DETAILS=never

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_HIBERNATE_SQL=INFO
